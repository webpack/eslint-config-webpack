{
  "name": "eslint-config-webpack",
  "version": "4.9.5",
  "description": "Provides Webpack's eslint rules as an extensible shared config",
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "webpack",
    "javascript",
    "typescript"
  ],
  "homepage": "https://github.com/webpack/eslint-config-webpack#readme",
  "bugs": {
    "url": "https://github.com/webpack/eslint-config-webpack/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webpack/eslint-config-webpack.git"
  },
  "license": "MIT",
  "author": "Joshua Wiens (https://twitter.com/@d3viant0ne)",
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js",
    "plugins",
    "prettier-config.js",
    "prettier-config-es5.js",
    "configs.js",
    "ignore-paths.js",
    "configs"
  ],
  "scripts": {
    "lint": "npm run lint:code && npm run lint:types",
    "lint:code": "eslint --cache .",
    "lint:types": "tsc -p tsconfig.internal.json",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "@eslint/markdown": "^8.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "detect-indent": "^7.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.4.0",
    "jsonc-eslint-parser": "^3.1.0",
    "semver": "^7.7.4",
    "sort-package-json": "^3.6.0",
    "typescript-eslint": "^8.58.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/get-github-info": "^0.8.0",
    "@types/semver": "^7.7.1",
    "eslint": "^9.39.2",
    "eslint-find-rules": "^5.0.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "type-fest": "^5.5.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "eslint": ">= 9.28.0",
    "typescript": ">=4.8.4 <7.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">= 20.9.0"
  }
}
